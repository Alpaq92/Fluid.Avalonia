<UserControl
    x:Class="Fluid.Avalonia.Demo.Views.Pages.TextPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls">

    <UserControl.Styles>
        <!-- Reveal toggle: Hide glyph when masked, RedEye when revealed. -->
        <Style Selector="ToggleButton.reveal TextBlock">
            <Setter Property="Text" Value="&#xED1A;" />
        </Style>
        <Style Selector="ToggleButton.reveal:checked TextBlock">
            <Setter Property="Text" Value="&#xE7B3;" />
        </Style>
    </UserControl.Styles>

    <StackPanel>

        <ctrls:ControlExample Header="A single-line TextBox."
                              XamlSource="&lt;TextBox PlaceholderText=&quot;Enter your name&quot; /&gt;">
            <TextBox Width="280" PlaceholderText="Enter your name" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A TextBox with clear button enabled."
                              XamlSource="&lt;TextBox Text=&quot;Editable text&quot; /&gt;">
            <TextBox Width="280" Text="Editable text" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A multi-line, wrapping TextBox."
                              XamlSource="&lt;TextBox AcceptsReturn=&quot;True&quot; TextWrapping=&quot;Wrap&quot; /&gt;">
            <TextBox
                Width="320"
                Height="110"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                PlaceholderText="Type a few lines…" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A password box with a show / hide reveal toggle."
                              XamlSource="&lt;TextBox PasswordChar=&quot;&#x2022;&quot; RevealPassword=&quot;{Binding #Reveal.IsChecked}&quot;&gt;&lt;TextBox.InnerRightContent&gt;&lt;ToggleButton x:Name=&quot;Reveal&quot; /&gt;&lt;/TextBox.InnerRightContent&gt;&lt;/TextBox&gt;">
            <TextBox Width="280" PasswordChar="•" PlaceholderText="Password"
                     Text="hunter2"
                     RevealPassword="{Binding #RevealBtn.IsChecked}">
                <TextBox.InnerRightContent>
                    <ToggleButton x:Name="RevealBtn" Classes="reveal"
                                  Background="Transparent" BorderThickness="0"
                                  VerticalAlignment="Stretch" Padding="8,0" Margin="0,0,2,0"
                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16"
                                   LineHeight="16" TextAlignment="Center"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ToggleButton>
                </TextBox.InnerRightContent>
            </TextBox>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="An AutoCompleteBox suggests items as you type."
                              XamlSource="&lt;AutoCompleteBox PlaceholderText=&quot;Search fruit…&quot; /&gt;">
            <AutoCompleteBox x:Name="FruitBox" Width="280" PlaceholderText="Search fruit…" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A NumericUpDown for numeric entry."
                              XamlSource="&lt;NumericUpDown Minimum=&quot;0&quot; Maximum=&quot;100&quot; Value=&quot;42&quot; /&gt;">
            <NumericUpDown Width="200" Minimum="0" Maximum="100" Value="42" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="The Fluent 2 type ramp."
                              XamlSource="&lt;TextBlock Classes=&quot;Display&quot; Text=&quot;Display&quot; /&gt;&lt;TextBlock Classes=&quot;Title&quot; Text=&quot;Title&quot; /&gt;&lt;TextBlock Classes=&quot;Body&quot; Text=&quot;Body&quot; /&gt;">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="Display" />
                <TextBlock Classes="TitleLarge" Text="Title large" />
                <TextBlock Classes="Title" Text="Title" />
                <TextBlock Classes="Subtitle" Text="Subtitle" />
                <TextBlock Classes="BodyStrong" Text="Body strong" />
                <TextBlock Classes="Body" Text="Body" />
                <TextBlock Classes="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Caption" />
            </StackPanel>
        </ctrls:ControlExample>

    </StackPanel>
</UserControl>
