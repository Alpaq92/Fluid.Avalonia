<UserControl
    x:Class="Fluid.Avalonia.Demo.Views.Pages.MediaPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls">

    <StackPanel>

        <ctrls:ControlExample Header="A media transport bar built from a Slider and command buttons."
                              XamlSource="&lt;DockPanel&gt;&lt;Button DockPanel.Dock=&quot;Left&quot; /&gt;&lt;Slider Minimum=&quot;0&quot; Maximum=&quot;100&quot; Value=&quot;35&quot; /&gt;&lt;/DockPanel&gt;">
            <Border
                Width="520"
                Padding="12,8"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource ControlCornerRadius}">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Width="36" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEB2C;" />
                    </Button>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                        <Button Width="36" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                            <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEB75;" />
                        </Button>
                        <Button Width="36" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                            <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEB4C;" />
                        </Button>
                    </StackPanel>
                    <Slider Margin="8,0" VerticalAlignment="Center" Minimum="0" Maximum="100" Value="35" />
                </DockPanel>
            </Border>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="An Image control displays a bitmap."
                              XamlSource="&lt;Image Source=&quot;avares://Fluid.Avalonia.Demo/Assets/logo.png&quot; /&gt;">
            <Border
                Padding="16"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource ControlCornerRadius}">
                <Image Width="96" Height="96"
                       Source="avares://Fluid.Avalonia.Demo/Assets/logo.png" />
            </Border>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="PathIcon draws a vector glyph from geometry data."
                              XamlSource="&lt;PathIcon Data=&quot;M8,5.14V19.14L19,12.14L8,5.14Z&quot; /&gt;">
            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <PathIcon Width="22" Height="22"
                          Data="M8,5.14V19.14L19,12.14L8,5.14Z" />
                <PathIcon Width="22" Height="22"
                          Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,7H13V13H11V7M11,15H13V17H11V15Z" />
                <PathIcon Width="22" Height="22"
                          Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z" />
                <PathIcon Width="22" Height="22"
                          Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" />
            </StackPanel>
        </ctrls:ControlExample>

    </StackPanel>
</UserControl>
