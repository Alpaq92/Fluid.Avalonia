<UserControl
    x:Class="Fluid.Avalonia.Demo.Views.Pages.BasicInputPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls"
    xmlns:models="using:Fluid.Avalonia.Demo.Models">

    <StackPanel>

        <ctrls:ControlExample Header="A simple Button with text content."
                              XamlSource="&lt;Button Content=&quot;Standard&quot; /&gt;">
            <Button Content="Standard" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="An accent-styled Button."
                              XamlSource="&lt;Button Classes=&quot;accent&quot; Content=&quot;Accent&quot; /&gt;">
            <Button x:Name="AccentButton" Classes="accent" Content="Accent" />
            <ctrls:ControlExample.Options>
                <StackPanel Spacing="8">
                    <CheckBox Content="Enabled" IsChecked="{Binding #AccentButton.IsEnabled, Mode=TwoWay}" />
                </StackPanel>
            </ctrls:ControlExample.Options>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A HyperlinkButton navigates to a URL."
                              XamlSource="&lt;HyperlinkButton NavigateUri=&quot;https://github.com/Alpaq92/Fluid.Avalonia&quot; Content=&quot;Fluid.Avalonia on GitHub&quot; /&gt;">
            <HyperlinkButton Content="Fluid.Avalonia on GitHub"
                             NavigateUri="https://github.com/Alpaq92/Fluid.Avalonia" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A RepeatButton fires Click repeatedly while pressed."
                              XamlSource="&lt;RepeatButton Content=&quot;Repeat&quot; /&gt;">
            <RepeatButton Content="Repeat" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ToggleButton keeps its checked state."
                              XamlSource="&lt;ToggleButton Content=&quot;Toggle&quot; /&gt;">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleButton Content="Toggle" />
                <ToggleButton Content="Checked" IsChecked="True" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A DropDownButton with a flyout."
                              XamlSource="&lt;DropDownButton Content=&quot;Options&quot; /&gt;">
            <DropDownButton Content="Options">
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="Copy" />
                        <MenuItem Header="Paste" />
                        <Separator />
                        <MenuItem Header="Delete" />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A SplitButton: primary action plus a flyout."
                              XamlSource="&lt;SplitButton Content=&quot;Save&quot; /&gt;">
            <SplitButton Content="Save">
                <SplitButton.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="Save as…" />
                        <MenuItem Header="Save a copy" />
                    </MenuFlyout>
                </SplitButton.Flyout>
            </SplitButton>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ToggleSplitButton keeps a checked state, plus a flyout."
                              XamlSource="&lt;ToggleSplitButton Content=&quot;Bullets&quot; /&gt;">
            <ToggleSplitButton Content="Bullets" IsChecked="True">
                <ToggleSplitButton.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="Disc" />
                        <MenuItem Header="Circle" />
                        <MenuItem Header="Square" />
                    </MenuFlyout>
                </ToggleSplitButton.Flyout>
            </ToggleSplitButton>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="CheckBoxes, including a three-state checkbox."
                              XamlSource="&lt;CheckBox Content=&quot;Two-state&quot; /&gt;">
            <StackPanel Spacing="8">
                <CheckBox Content="Unchecked" />
                <CheckBox Content="Checked" IsChecked="True" />
                <CheckBox Content="Indeterminate" IsThreeState="True" IsChecked="{x:Null}" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="RadioButtons let a user pick one option from a set."
                              XamlSource="&lt;RadioButton Content=&quot;Option&quot; GroupName=&quot;g&quot; /&gt;">
            <StackPanel Spacing="8">
                <RadioButton Content="Option 1" GroupName="demo" IsChecked="True" />
                <RadioButton Content="Option 2" GroupName="demo" />
                <RadioButton Content="Option 3" GroupName="demo" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ToggleSwitch turns a setting on or off.">
            <ToggleSwitch x:Name="DemoSwitch" IsChecked="True" />
            <ctrls:ControlExample.Options>
                <StackPanel Spacing="8">
                    <CheckBox Content="Enabled" IsChecked="{Binding #DemoSwitch.IsEnabled, Mode=TwoWay}" />
                </StackPanel>
            </ctrls:ControlExample.Options>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A BinarySelector picks between two values: both options show inside the track, an accent pill slides to the active one, and Value returns the chosen object."
                              XamlSource="&lt;ctrls:BinarySelector LeftValue=&quot;AM&quot; RightValue=&quot;PM&quot; /&gt;">
            <StackPanel Spacing="10">
                <ctrls:BinarySelector x:Name="PeriodSelector" LeftValue="AM" RightValue="PM" />
                <TextBlock Classes="Caption"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding #PeriodSelector.Value, StringFormat='Value: {0}'}" />
            </StackPanel>
            <ctrls:ControlExample.Options>
                <StackPanel Spacing="8">
                    <CheckBox Content="Enabled" IsChecked="{Binding #PeriodSelector.IsEnabled, Mode=TwoWay}" />
                </StackPanel>
            </ctrls:ControlExample.Options>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A Slider selects a value from a range."
                              XamlSource="&lt;Slider Minimum=&quot;0&quot; Maximum=&quot;100&quot; Value=&quot;40&quot; /&gt;">
            <Slider Width="280" Minimum="0" Maximum="100" Value="40" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A RadialSlider — a circular slider whose accent fill and thumb sweep from 12 o'clock; drag the ring to set the value."
                              XamlSource="&lt;ctrls:RadialSlider Value=&quot;40&quot; /&gt;">
            <StackPanel Spacing="12" HorizontalAlignment="Left">
                <ctrls:RadialSlider x:Name="RadSlider" Value="40" />
                <TextBlock Classes="Caption"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding #RadSlider.Value, StringFormat='Value: {0:0}'}" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ComboBox lets a user choose from a list."
                              XamlSource="&lt;ComboBox SelectedIndex=&quot;0&quot; /&gt;">
            <ComboBox Width="200" SelectedIndex="0">
                <ComboBoxItem>Apple</ComboBoxItem>
                <ComboBoxItem>Banana</ComboBoxItem>
                <ComboBoxItem>Cherry</ComboBoxItem>
            </ComboBox>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="An AutoCompleteBox autocompletes as you type (try typing a country)."
                              XamlSource="&lt;AutoCompleteBox FilterMode=&quot;Contains&quot; MinimumPrefixLength=&quot;1&quot; PlaceholderText=&quot;Type a country…&quot; ItemsSource=&quot;{x:Static models:Countries.All}&quot; /&gt;">
            <AutoCompleteBox Width="260"
                             FilterMode="Contains"
                             MinimumPrefixLength="1"
                             PlaceholderText="Type a country…"
                             ItemsSource="{x:Static models:Countries.All}" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A NumericUpDown edits a number with spin buttons."
                              XamlSource="&lt;NumericUpDown Value=&quot;42&quot; /&gt;">
            <NumericUpDown Width="200" Value="42" Minimum="0" Maximum="100" Increment="1" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ButtonSpinner wraps any content with up / down spin buttons."
                              XamlSource="&lt;ButtonSpinner Content=&quot;Low&quot; /&gt;">
            <ButtonSpinner x:Name="LevelSpinner" Width="200" Content="Low" />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A Label captions another control (click to focus its target)."
                              XamlSource="&lt;Label Target=&quot;{Binding #Field}&quot; Content=&quot;_Name&quot; /&gt;&#10;&lt;TextBox x:Name=&quot;Field&quot; Width=&quot;220&quot; /&gt;">
            <StackPanel Spacing="4">
                <Label Target="{Binding #Field}" Content="_Name" />
                <TextBox x:Name="Field" Width="220" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A color dropdown with named tabs (Color Space / Preset / Sliders), matching the Accents page."
                              XamlSource="&lt;ctrls:FluidColorPicker /&gt;">
            <ctrls:FluidColorPicker />
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A LabeledTextInput pairs a label chip with a field (as used by the color sliders)."
                              XamlSource="&lt;ctrls:LabeledTextInput Label=&quot;Name&quot; Watermark=&quot;Your name&quot; /&gt;">
            <StackPanel Spacing="8">
                <ctrls:LabeledTextInput Label="Name" Watermark="Your name" />
                <ctrls:LabeledTextInput Label="@" Watermark="you@example.com" />
                <ctrls:LabeledTextInput Label="R" Text="255" />
            </StackPanel>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A modal Window — open one to check a native Avalonia Window (available only on Desktops, blocked in Browser view).">
            <Button x:Name="OpenWindowButton" Content="Open a modal Window" />
        </ctrls:ControlExample>

    </StackPanel>
</UserControl>
