<!--
    MainView — the gallery shell (custom title-bar row + NavigationView-style SplitView). Hosted by
    MainWindow on desktop (inside the extended client area, with the window caption buttons) and used
    directly as the single top-level on the Browser (WASM) head. Window-coupled bits (drag, caption
    buttons, maximize glyph) resolve the hosting Window at runtime and are hidden when there isn't one.
-->
<UserControl
    x:Class="Fluid.Avalonia.Demo.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:Fluid.Avalonia.Demo.Models">

    <UserControl.Styles>
        <Style Selector="Button.caption">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style Selector="Button.caption /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.caption:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.caption:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
        </Style>
        <Style Selector="Button.caption-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C42B1C" />
        </Style>
        <Style Selector="Button.caption-close:pointerover TextBlock">
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="48,*">

        <!--======================= CUSTOM TITLE BAR =======================-->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent"
              ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">

            <Button x:Name="Hamburger" Grid.Column="0"
                    Width="44" Height="40" Margin="4,0,0,0" Padding="0"
                    Background="Transparent" BorderThickness="0" CornerRadius="0" MinHeight="0">
                <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEB94;" />
            </Button>

            <Image x:Name="AppIcon" Grid.Column="1" Width="18" Height="18" Margin="6,0,0,0"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   Source="avares://Fluid.Avalonia.Demo/Assets/logo.png" />

            <!-- Text is set in code from typeof(App).Namespace (Fluid.Avalonia.Demo), not hardcoded. -->
            <TextBlock x:Name="AppTitle" Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center"
                       Classes="Caption" />

            <AutoCompleteBox x:Name="SearchBox" Grid.Column="3"
                             Width="460" MaxWidth="560" Height="32"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             FilterMode="Contains"
                             PlaceholderText="Search controls and samples…" />

            <!-- Page prev/next — steps through the nav pages (and Settings). Always visible (works on
                 the browser head too, where there are no window caption buttons). -->
            <StackPanel x:Name="PageNavButtons" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="PrevPageBtn" Classes="caption" ToolTip.Tip="Previous page">
                    <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="12" Text="&#xEAB7;" />
                </Button>
                <Button x:Name="NextPageBtn" Classes="caption" ToolTip.Tip="Next page">
                    <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="12" Text="&#xEAB4;" />
                </Button>
            </StackPanel>

            <StackPanel x:Name="CaptionButtons" Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="MinBtn" Classes="caption">
                    <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="10" Text="&#xEABA;" />
                </Button>
                <Button x:Name="MaxBtn" Classes="caption">
                    <TextBlock x:Name="MaxGlyph" FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="10" Text="&#xEAB9;" />
                </Button>
                <Button x:Name="CloseBtn" Classes="caption caption-close">
                    <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="10" Text="&#xEAB8;" />
                </Button>
            </StackPanel>
        </Grid>

        <!--======================= SHELL =======================-->
        <SplitView
            x:Name="Split"
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="280"
            Background="Transparent"
            PaneBackground="Transparent">

            <SplitView.Pane>
                <DockPanel Margin="0,4,0,0">
                    <ListBox
                        x:Name="FooterNav"
                        DockPanel.Dock="Bottom"
                        Margin="0,4,0,8"
                        Background="Transparent"
                        BorderThickness="0">
                        <ListBoxItem Theme="{StaticResource NavItem}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEB51;" VerticalAlignment="Center" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <ScrollViewer>
                        <ListBox
                            x:Name="NavList"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerTheme="{StaticResource NavItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:GalleryItem">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="{Binding Glyph}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </SplitView.Pane>

            <Border
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,0,0"
                CornerRadius="8,0,0,0">
                <!-- The page inset lives on the content's Margin, NOT on ScrollViewer.Padding:
                     Avalonia's ScrollViewer subtracts its Padding from the scrollable extent, which
                     clips the last (vertical-padding worth of) content out of reach. As a Margin it's
                     counted into the content's desired size, so the whole page can scroll into view. -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ContentControl x:Name="ContentHost" Margin="36,28,44,28" HorizontalAlignment="Stretch" />
                </ScrollViewer>
            </Border>
        </SplitView>
    </Grid>
</UserControl>
