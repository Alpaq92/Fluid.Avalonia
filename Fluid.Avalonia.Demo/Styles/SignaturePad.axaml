<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls">

    <!-- SignaturePad derives from Control and hand-paints its surface, hairline, rounded corners and
         ink in Render (Border seals Render, so it can't host custom drawing). The drawn background also
         makes it hit-testable. A ControlTheme wouldn't auto-apply to a non-templated Control, so these
         Fluent defaults live in a plain Style. -->
    <Style Selector="ctrls|SignaturePad">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource OverlayCornerRadius}" />
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

</Styles>
