<!--
    FluidColorPicker — a Fluid-styled color dropdown for the demo.

    The bundled ColorPicker opens a ColorView whose tab strip uses bare icon glyphs and a button
    that shows only a swatch. This control instead shows the picked color's swatch *and* its hex
    on a DropDownButton, and hosts the shared FluidColorEditor surface (the same editors the
    Accents page uses) in its flyout.
-->
<UserControl
    x:Class="Fluid.Avalonia.Demo.Controls.FluidColorPicker"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls">

    <DropDownButton x:Name="Trigger"
                    Padding="10,0"
                    MinWidth="140"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border x:Name="Swatch"
                    Width="20" Height="20"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1" />
            <TextBlock x:Name="HexText"
                       VerticalAlignment="Center"
                       FontFamily="Consolas, Cascadia Mono, monospace"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </StackPanel>

        <DropDownButton.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
                <ctrls:FluidColorEditor x:Name="Editor" />
            </Flyout>
        </DropDownButton.Flyout>
    </DropDownButton>
</UserControl>
