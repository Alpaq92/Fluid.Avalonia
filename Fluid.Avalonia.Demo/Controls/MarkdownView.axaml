<UserControl
    x:Class="Fluid.Avalonia.Demo.Controls.MarkdownView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
    xmlns:mdc="clr-namespace:Markdown.Avalonia.Controls;assembly=Markdown.Avalonia"
    xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia">

    <Border
        x:Name="Card"
        Padding="28,24"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="{DynamicResource OverlayCornerRadius}">
        <md:MarkdownScrollViewer
            x:Name="Md"
            HorizontalAlignment="Left"
            Markdown="">

            <!-- Fluent 2-integrated markdown styling (theme-aware via *Brush tokens). -->
            <md:MarkdownScrollViewer.MarkdownStyle>
                <Styles>

                    <!-- Body text -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock">
                        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Setter Property="Margin" Value="0,5" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer TextBlock">
                        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Style>

                    <!-- Headings: WinUI type ramp -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading1">
                        <Setter Property="FontFamily" Value="{DynamicResource WinUIFontFamilyDisplay}" />
                        <Setter Property="FontSize" Value="32" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Setter Property="Margin" Value="0,4,0,10" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading2">
                        <Setter Property="FontSize" Value="22" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Setter Property="Margin" Value="0,20,0,6" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading3">
                        <Setter Property="FontSize" Value="17" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Setter Property="Margin" Value="0,14,0,4" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading4">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Setter Property="Margin" Value="0,12,0,4" />
                    </Style>

                    <!-- Inline code -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CCode">
                        <Setter Property="FontFamily" Value="Cascadia Mono, Cascadia Code, Consolas, monospace" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    </Style>

                    <!-- Fenced code block -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.CodeBlock">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Padding" Value="14,10" />
                        <Setter Property="Margin" Value="0,8" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer TextBlock.CodeBlock">
                        <Setter Property="FontFamily" Value="Cascadia Mono, Cascadia Code, Consolas, monospace" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.CodeBlock">
                        <Setter Property="FontFamily" Value="Cascadia Mono, Cascadia Code, Consolas, monospace" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Style>

                    <!-- Links -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CHyperlink">
                        <Setter Property="IsUnderline" Value="False" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <Setter Property="HoverForeground" Value="{DynamicResource AccentTextFillColorSecondaryBrush}" />
                    </Style>

                    <!-- Lists -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Grid.List">
                        <Setter Property="Margin" Value="22,0,0,0" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.ListMarker">
                        <Setter Property="Margin" Value="0,5,8,5" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Style>

                    <!-- Blockquote -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.Blockquote">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="4,0,0,0" />
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        <Setter Property="CornerRadius" Value="0,4,4,0" />
                        <Setter Property="Margin" Value="0,8" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer StackPanel.Blockquote">
                        <Setter Property="Margin" Value="14,6" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.Blockquote ctxt|CTextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Style>

                    <!-- Horizontal rule -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer mdc|Rule">
                        <Setter Property="Margin" Value="0,14" />
                    </Style>

                    <!-- ============ Tables ============ -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Grid.Table">
                        <Setter Property="mdc:AutoScaleColumnDefinitions.IsEnabled" Value="True" />
                    </Style>
                    <!-- Outer frame: no border line (it read as a hard outline on light); just a
                         rounded, clipped, subtly-tinted surface to host the zebra rows. -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.Table">
                        <Setter Property="Margin" Value="0,10" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="ClipToBounds" Value="True" />
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.TightTable">
                        <Setter Property="HorizontalAlignment" Value="Left" />
                    </Style>
                    <!-- Cells: no internal gridlines — a full grid of hairlines reads as hard
                         outlines on a light background. Comfortable padding + zebra striping +
                         a single header underline carry the structure instead. -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Grid.Table > Border">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="14,9" />
                    </Style>
                    <!-- Header row: subtle underline only -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.TableHeader">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.TableHeader ctxt|CTextBlock">
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Style>
                    <!-- Zebra striping -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.OddTableRow">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.EvenTableRow">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                    </Style>

                </Styles>
            </md:MarkdownScrollViewer.MarkdownStyle>
        </md:MarkdownScrollViewer>
    </Border>
</UserControl>
