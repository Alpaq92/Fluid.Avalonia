<!--
    RadialClock — the concentric ring-slider clock dial on its own (no field, no OK/Cancel): a clock
    face whose INNER ring is the hour and OUTER ring the minute (each a Fluent slider bent into a
    circle), with the time readout + an AM/PM BinarySelector centred inside the inner ring. It edits its
    TwoWay Time live as you drag; hosts seed Time on open and read it back on commit. Is24Hour switches
    to the Material 24-hour layout (0–23, no AM/PM) — then only the centred time shows. Used by
    RadialTimePicker and AnalogDateTimePicker so the dial is identical in both.
-->
<UserControl
    x:Class="Fluid.Avalonia.Demo.Controls.RadialClock"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Fluid.Avalonia.Demo.Controls">

    <Grid Width="256" Height="256">
        <!-- The dial: backing disc + (code-built) rings, numbers and thumbs. -->
        <Canvas x:Name="Face" Width="256" Height="256" Background="Transparent">
            <!-- Backing disc — the calendar's surface colour, so the dial reads as a matching round
                 card (used inline next to a Calendar and in the picker dropdowns). -->
            <Ellipse Width="220" Height="220" Canvas.Left="18" Canvas.Top="18"
                     Fill="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                     IsHitTestVisible="False" />
        </Canvas>

        <!-- Time readout + AM/PM, centred inside the inner hour ring. AM/PM is our BinarySelector
             (compact variant so it fits); 24-hour hides it and shows only the time. -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock x:Name="Header" FontSize="22" HorizontalAlignment="Center" Text="9:00" />
            <ctrls:BinarySelector x:Name="AmPmSelector" Classes="compact"
                                  LeftValue="AM" RightValue="PM" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
