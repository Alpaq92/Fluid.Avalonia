<!--
    RadialSlider — a circular slider: one ring (a Fluent slider bent into a circle) whose accent fill
    and draggable thumb sweep clockwise from 12 o'clock to represent Value in [Minimum, Maximum], with
    the value shown in the centre. Ring geometry / hit-testing come from the shared RadialDial helper,
    so it matches the RadialTimePicker dial and the stock Slider's default / hover / pressed states.
-->
<UserControl
    x:Class="Fluid.Avalonia.Demo.Controls.RadialSlider"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="140" Height="140">
        <Canvas x:Name="Face" Width="140" Height="140" Background="Transparent" />
        <TextBlock x:Name="ValueText" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
    </Grid>
</UserControl>
