<Styles
    x:Class="Fluid.Avalonia.FluidTheme"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FluentTheme is the Fluent/WinUI-derived base we refine. -->
    <FluentTheme />

    <!-- WinUI 3 resource overrides win over FluentTheme (Styles.Resources is consulted first). -->
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Fluid.Avalonia/Resources/Fluent2Colors.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Resources/Elevation.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Resources/ThemeResources.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/Button.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/ControlColors.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/ScrollBar.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/Calendar.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/NumericUpDown.axaml" />
                <ResourceInclude Source="avares://Fluid.Avalonia/Controls/FluidWindow.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Per-control refinements. -->
    <StyleInclude Source="avares://Fluid.Avalonia/Controls.axaml" />

</Styles>
