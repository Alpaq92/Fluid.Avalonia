<!--
    Fluent 2 / WinUI 3 color tokens.

    Values are taken from WinUI 3 Common_themeresources. Each token is published both as a
    Color (<Token>) and a SolidColorBrush (<Token>Brush), matching WinUI naming so markup can
    use either. Accent-derived brushes resolve through the live accent shades that
    AccentColorService publishes (SystemAccentColor / ...Light1-3 / ...Dark1-3).

    Light values live under the "Default" theme dictionary (Light variants fall back to it);
    Dark values live under "Dark".
-->
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!--========================= LIGHT =========================-->
        <ResourceDictionary x:Key="Default">

            <!-- Text -->
            <Color x:Key="TextFillColorPrimary">#E4000000</Color>
            <Color x:Key="TextFillColorSecondary">#9E000000</Color>
            <Color x:Key="TextFillColorTertiary">#72000000</Color>
            <Color x:Key="TextFillColorDisabled">#5C000000</Color>
            <Color x:Key="TextOnAccentFillColorPrimary">#FFFFFFFF</Color>
            <Color x:Key="TextOnAccentFillColorSecondary">#B3FFFFFF</Color>
            <Color x:Key="TextOnAccentFillColorDisabled">#FFFFFFFF</Color>

            <!-- Control fills -->
            <Color x:Key="ControlFillColorDefault">#B3FFFFFF</Color>
            <Color x:Key="ControlFillColorSecondary">#80F9F9F9</Color>
            <Color x:Key="ControlFillColorTertiary">#4DF9F9F9</Color>
            <Color x:Key="ControlFillColorDisabled">#4DF9F9F9</Color>
            <Color x:Key="ControlFillColorTransparent">#00FFFFFF</Color>
            <Color x:Key="ControlStrongFillColorDefault">#72000000</Color>
            <Color x:Key="ControlStrongFillColorDisabled">#51000000</Color>
            <Color x:Key="ControlSolidFillColorDefault">#FFFFFFFF</Color>
            <Color x:Key="ControlFillColorInputActive">#FFFFFFFF</Color>
            <Color x:Key="ControlAltFillColorSecondary">#06000000</Color>
            <Color x:Key="ControlAltFillColorTertiary">#0F000000</Color>
            <Color x:Key="ControlAltFillColorQuarternary">#18000000</Color>
            <Color x:Key="ControlAltFillColorDisabled">#00FFFFFF</Color>

            <!-- Subtle fills (hover/press backplates) -->
            <Color x:Key="SubtleFillColorTransparent">#00FFFFFF</Color>
            <Color x:Key="SubtleFillColorSecondary">#09000000</Color>
            <Color x:Key="SubtleFillColorTertiary">#06000000</Color>
            <Color x:Key="SubtleFillColorDisabled">#00FFFFFF</Color>

            <!-- Surfaces -->
            <Color x:Key="CardBackgroundFillColorDefault">#B3FFFFFF</Color>
            <Color x:Key="CardBackgroundFillColorSecondary">#80F6F6F6</Color>
            <Color x:Key="LayerFillColorDefault">#80FFFFFF</Color>
            <Color x:Key="LayerFillColorAlt">#FFFFFFFF</Color>
            <Color x:Key="LayerOnAcrylicFillColorDefault">#40FFFFFF</Color>
            <Color x:Key="SolidBackgroundFillColorBase">#FFF3F3F3</Color>
            <Color x:Key="SolidBackgroundFillColorSecondary">#FFEEEEEE</Color>
            <Color x:Key="SolidBackgroundFillColorTertiary">#FFF9F9F9</Color>
            <Color x:Key="SolidBackgroundFillColorQuarternary">#FFFFFFFF</Color>
            <Color x:Key="SolidBackgroundFillColorBaseAlt">#FFDADADA</Color>
            <Color x:Key="AcrylicInAppFillColorDefault">#FFF9F9F9</Color>
            <Color x:Key="AcrylicBackgroundFillColorDefault">#FFF3F3F3</Color>
            <Color x:Key="SmokeFillColorDefault">#4D000000</Color>

            <!-- Strokes -->
            <Color x:Key="ControlStrokeColorDefault">#0F000000</Color>
            <Color x:Key="ControlStrokeColorSecondary">#29000000</Color>
            <Color x:Key="ControlStrongStrokeColorDefault">#72000000</Color>
            <Color x:Key="ControlStrongStrokeColorDisabled">#37000000</Color>
            <Color x:Key="ControlStrokeColorOnAccentDefault">#14FFFFFF</Color>
            <Color x:Key="ControlStrokeColorOnAccentSecondary">#66000000</Color>
            <Color x:Key="CardStrokeColorDefault">#0F000000</Color>
            <Color x:Key="DividerStrokeColorDefault">#0F000000</Color>
            <Color x:Key="SurfaceStrokeColorDefault">#66757575</Color>

            <!-- Accent (disabled is fixed; live shades drive the rest via brushes below) -->
            <Color x:Key="AccentFillColorDisabled">#37000000</Color>

            <!-- System signal colors -->
            <Color x:Key="SystemFillColorSuccess">#FF0F7B0F</Color>
            <Color x:Key="SystemFillColorCaution">#FF9D5D00</Color>
            <Color x:Key="SystemFillColorCritical">#FFC42B1C</Color>
            <Color x:Key="SystemFillColorNeutral">#72000000</Color>
            <Color x:Key="SystemFillColorAttention">#FF005FB8</Color>
            <Color x:Key="SystemFillColorSuccessBackground">#FFDFF6DD</Color>
            <Color x:Key="SystemFillColorCautionBackground">#FFFFF4CE</Color>
            <Color x:Key="SystemFillColorCriticalBackground">#FFFDE7E9</Color>
            <Color x:Key="SystemFillColorAttentionBackground">#80F6F6F6</Color>

            <!-- Accent-derived brushes (light theme uses darker accent shades) -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{DynamicResource SystemAccentColorDark1}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{DynamicResource SystemAccentColorDark1}" Opacity="0.9" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{DynamicResource SystemAccentColorDark2}" Opacity="0.8" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{DynamicResource SystemAccentColorDark2}" />
            <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{DynamicResource SystemAccentColorDark3}" />
        </ResourceDictionary>

        <!--========================= DARK =========================-->
        <ResourceDictionary x:Key="Dark">

            <!-- Text -->
            <Color x:Key="TextFillColorPrimary">#FFFFFFFF</Color>
            <Color x:Key="TextFillColorSecondary">#C5FFFFFF</Color>
            <Color x:Key="TextFillColorTertiary">#87FFFFFF</Color>
            <Color x:Key="TextFillColorDisabled">#5DFFFFFF</Color>
            <Color x:Key="TextOnAccentFillColorPrimary">#FF000000</Color>
            <Color x:Key="TextOnAccentFillColorSecondary">#80000000</Color>
            <Color x:Key="TextOnAccentFillColorDisabled">#87FFFFFF</Color>

            <!-- Control fills -->
            <Color x:Key="ControlFillColorDefault">#0FFFFFFF</Color>
            <Color x:Key="ControlFillColorSecondary">#15FFFFFF</Color>
            <Color x:Key="ControlFillColorTertiary">#08FFFFFF</Color>
            <Color x:Key="ControlFillColorDisabled">#0BFFFFFF</Color>
            <Color x:Key="ControlFillColorTransparent">#00FFFFFF</Color>
            <Color x:Key="ControlStrongFillColorDefault">#8BFFFFFF</Color>
            <Color x:Key="ControlStrongFillColorDisabled">#3FFFFFFF</Color>
            <Color x:Key="ControlSolidFillColorDefault">#FF454545</Color>
            <Color x:Key="ControlFillColorInputActive">#B31E1E1E</Color>
            <Color x:Key="ControlAltFillColorSecondary">#19000000</Color>
            <Color x:Key="ControlAltFillColorTertiary">#0BFFFFFF</Color>
            <Color x:Key="ControlAltFillColorQuarternary">#12FFFFFF</Color>
            <Color x:Key="ControlAltFillColorDisabled">#00FFFFFF</Color>

            <!-- Subtle fills -->
            <Color x:Key="SubtleFillColorTransparent">#00FFFFFF</Color>
            <Color x:Key="SubtleFillColorSecondary">#0FFFFFFF</Color>
            <Color x:Key="SubtleFillColorTertiary">#0AFFFFFF</Color>
            <Color x:Key="SubtleFillColorDisabled">#00FFFFFF</Color>

            <!-- Surfaces -->
            <Color x:Key="CardBackgroundFillColorDefault">#0DFFFFFF</Color>
            <Color x:Key="CardBackgroundFillColorSecondary">#08FFFFFF</Color>
            <Color x:Key="LayerFillColorDefault">#4C3A3A3A</Color>
            <Color x:Key="LayerFillColorAlt">#0DFFFFFF</Color>
            <Color x:Key="LayerOnAcrylicFillColorDefault">#09FFFFFF</Color>
            <Color x:Key="SolidBackgroundFillColorBase">#FF202020</Color>
            <Color x:Key="SolidBackgroundFillColorSecondary">#FF1C1C1C</Color>
            <Color x:Key="SolidBackgroundFillColorTertiary">#FF282828</Color>
            <Color x:Key="SolidBackgroundFillColorQuarternary">#FF2C2C2C</Color>
            <Color x:Key="SolidBackgroundFillColorBaseAlt">#FF0A0A0A</Color>
            <Color x:Key="AcrylicInAppFillColorDefault">#FF2C2C2C</Color>
            <Color x:Key="AcrylicBackgroundFillColorDefault">#FF202020</Color>
            <Color x:Key="SmokeFillColorDefault">#4D000000</Color>

            <!-- Strokes -->
            <Color x:Key="ControlStrokeColorDefault">#12FFFFFF</Color>
            <Color x:Key="ControlStrokeColorSecondary">#18FFFFFF</Color>
            <Color x:Key="ControlStrongStrokeColorDefault">#8BFFFFFF</Color>
            <Color x:Key="ControlStrongStrokeColorDisabled">#28FFFFFF</Color>
            <Color x:Key="ControlStrokeColorOnAccentDefault">#14FFFFFF</Color>
            <Color x:Key="ControlStrokeColorOnAccentSecondary">#23000000</Color>
            <Color x:Key="CardStrokeColorDefault">#19000000</Color>
            <Color x:Key="DividerStrokeColorDefault">#15FFFFFF</Color>
            <Color x:Key="SurfaceStrokeColorDefault">#66757575</Color>

            <!-- Accent -->
            <Color x:Key="AccentFillColorDisabled">#28FFFFFF</Color>

            <!-- System signal colors -->
            <Color x:Key="SystemFillColorSuccess">#FF6CCB5F</Color>
            <Color x:Key="SystemFillColorCaution">#FFFCE100</Color>
            <Color x:Key="SystemFillColorCritical">#FFFF99A4</Color>
            <Color x:Key="SystemFillColorNeutral">#8BFFFFFF</Color>
            <Color x:Key="SystemFillColorAttention">#FF60CDFF</Color>
            <Color x:Key="SystemFillColorSuccessBackground">#FF393D1B</Color>
            <Color x:Key="SystemFillColorCautionBackground">#FF433519</Color>
            <Color x:Key="SystemFillColorCriticalBackground">#FF442726</Color>
            <Color x:Key="SystemFillColorAttentionBackground">#08FFFFFF</Color>

            <!-- Accent-derived brushes (dark theme uses lighter accent shades) -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{DynamicResource SystemAccentColorLight2}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{DynamicResource SystemAccentColorLight2}" Opacity="0.9" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{DynamicResource SystemAccentColorLight3}" Opacity="0.8" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{DynamicResource SystemAccentColorLight3}" />
            <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{DynamicResource SystemAccentColorLight2}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!--========================= THEME-AGNOSTIC BRUSHES =========================-->
    <!-- Each brush tracks its token Color via DynamicResource, so it follows the active theme. -->

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{DynamicResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{DynamicResource TextFillColorTertiary}" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{DynamicResource TextFillColorDisabled}" />
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{DynamicResource TextOnAccentFillColorPrimary}" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{DynamicResource TextOnAccentFillColorSecondary}" />
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{DynamicResource TextOnAccentFillColorDisabled}" />

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{DynamicResource ControlFillColorDefault}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{DynamicResource ControlFillColorSecondary}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{DynamicResource ControlFillColorTertiary}" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{DynamicResource ControlFillColorDisabled}" />
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="{DynamicResource ControlFillColorTransparent}" />
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="{DynamicResource ControlStrongFillColorDefault}" />
    <SolidColorBrush x:Key="ControlStrongFillColorDisabledBrush" Color="{DynamicResource ControlStrongFillColorDisabled}" />
    <SolidColorBrush x:Key="ControlSolidFillColorDefaultBrush" Color="{DynamicResource ControlSolidFillColorDefault}" />
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{DynamicResource ControlFillColorInputActive}" />
    <SolidColorBrush x:Key="ControlAltFillColorSecondaryBrush" Color="{DynamicResource ControlAltFillColorSecondary}" />
    <SolidColorBrush x:Key="ControlAltFillColorTertiaryBrush" Color="{DynamicResource ControlAltFillColorTertiary}" />
    <SolidColorBrush x:Key="ControlAltFillColorQuarternaryBrush" Color="{DynamicResource ControlAltFillColorQuarternary}" />
    <SolidColorBrush x:Key="ControlAltFillColorDisabledBrush" Color="{DynamicResource ControlAltFillColorDisabled}" />

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="{DynamicResource SubtleFillColorTransparent}" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{DynamicResource SubtleFillColorSecondary}" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{DynamicResource SubtleFillColorTertiary}" />
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="{DynamicResource SubtleFillColorDisabled}" />

    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{DynamicResource CardBackgroundFillColorDefault}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{DynamicResource CardBackgroundFillColorSecondary}" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{DynamicResource LayerFillColorDefault}" />
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{DynamicResource LayerFillColorAlt}" />
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{DynamicResource LayerOnAcrylicFillColorDefault}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{DynamicResource SolidBackgroundFillColorBase}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{DynamicResource SolidBackgroundFillColorTertiary}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{DynamicResource SolidBackgroundFillColorQuarternary}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseAltBrush" Color="{DynamicResource SolidBackgroundFillColorBaseAlt}" />
    <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultBrush" Color="{DynamicResource AcrylicInAppFillColorDefault}" />
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="{DynamicResource AcrylicBackgroundFillColorDefault}" />
    <SolidColorBrush x:Key="SmokeFillColorDefaultBrush" Color="{DynamicResource SmokeFillColorDefault}" />

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{DynamicResource ControlStrokeColorDefault}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{DynamicResource ControlStrokeColorSecondary}" />
    <SolidColorBrush x:Key="ControlStrongStrokeColorDefaultBrush" Color="{DynamicResource ControlStrongStrokeColorDefault}" />
    <SolidColorBrush x:Key="ControlStrongStrokeColorDisabledBrush" Color="{DynamicResource ControlStrongStrokeColorDisabled}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{DynamicResource CardStrokeColorDefault}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{DynamicResource DividerStrokeColorDefault}" />
    <SolidColorBrush x:Key="SurfaceStrokeColorDefaultBrush" Color="{DynamicResource SurfaceStrokeColorDefault}" />

    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{DynamicResource AccentFillColorDisabled}" />

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{DynamicResource SystemFillColorSuccess}" />
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{DynamicResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{DynamicResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{DynamicResource SystemFillColorNeutral}" />
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{DynamicResource SystemFillColorAttention}" />
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="{DynamicResource SystemFillColorSuccessBackground}" />
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="{DynamicResource SystemFillColorCautionBackground}" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="{DynamicResource SystemFillColorCriticalBackground}" />
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="{DynamicResource SystemFillColorAttentionBackground}" />

</ResourceDictionary>
