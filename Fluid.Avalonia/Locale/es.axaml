<ResourceDictionary
    x:Class="Fluid.Avalonia.Locale.es"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  Pickers  -->
    <x:String x:Key="STRING_OK">OK</x:String>
    <x:String x:Key="STRING_CANCEL">Cancelar</x:String>
    <x:String x:Key="STRING_RESET">Restablecer</x:String>
    <x:String x:Key="STRING_MONTH">mes</x:String>
    <x:String x:Key="STRING_DAY">día</x:String>
    <x:String x:Key="STRING_YEAR">año</x:String>
    <x:String x:Key="STRING_HOUR">hora</x:String>
    <x:String x:Key="STRING_MINUTE">min</x:String>
    <!--  Native Avalonia DatePicker / TimePicker field placeholders (override the FluentTheme defaults)  -->
    <x:String x:Key="StringDatePickerDayText">día</x:String>
    <x:String x:Key="StringDatePickerMonthText">mes</x:String>
    <x:String x:Key="StringDatePickerYearText">año</x:String>
    <x:String x:Key="StringTimePickerHourText">hora</x:String>
    <x:String x:Key="StringTimePickerMinuteText">minuto</x:String>
    <x:String x:Key="StringTimePickerSecondText">segundo</x:String>
    <!--  Native TextBox / input context menu (right-click Cut / Copy / Paste)  -->
    <x:String x:Key="StringTextFlyoutCutText">Cortar</x:String>
    <x:String x:Key="StringTextFlyoutCopyText">Copiar</x:String>
    <x:String x:Key="StringTextFlyoutPasteText">Pegar</x:String>
</ResourceDictionary>
