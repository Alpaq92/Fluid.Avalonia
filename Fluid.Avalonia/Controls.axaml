<!--
    Aggregates per-control style overrides layered on top of FluentTheme. New control
    refinements get their own file under Controls/ and are included here (Romzetron pattern).
-->
<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StyleInclude Source="avares://Fluid.Avalonia/Controls/Typography.axaml" />
    <StyleInclude Source="avares://Fluid.Avalonia/Controls/Card.axaml" />

    <!-- Default the whole window tree to the WinUI 3 typeface. -->
    <Style Selector="TopLevel">
        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
    </Style>

    <!-- A plain Window (OS-drawn title bar) takes the solid base background so its body reads as one
         surface with the dark caption. Exact-type selector — FluidWindow and other Window subclasses
         (which bring their own chrome / Mica) are left untouched. -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
    </Style>

    <!-- Button (incl. accent) is fully themed in Controls/Button.axaml.
         Give the remaining FluentTheme controls the WinUI "lit edge" gradient border. -->
    <Style Selector="ToggleButton">
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- NumericUpDown hosts a TextBox inside our themed ButtonSpinner; keep the inner field
         borderless so only the spinner's border shows (no doubled outline). -->
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinHeight" Value="0" />
    </Style>
    <!-- The base Background above only covers the rest state; the stock TextBox theme repaints
         its PART_BorderElement on pointer-over / focus, which showed as a lighter patch over just
         the text area (left) while the spinner side kept the ButtonSpinner hover fill — a two-tone
         field. Pin that inner border transparent in those states too, so the ButtonSpinner is the
         single field surface and the whole control hovers/focuses as one uniform shade. -->
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- The native DatePicker / TimePicker segment text gets no VerticalAlignment in the stock
         FluentTheme template (it's positioned by an asymmetric host padding of 0,3,0,6), so with a
         shorter-line-box font the day / month / year and hour : minute text sits high in the field.
         Center it explicitly so it's robust to whatever font the host app supplies. -->
    <Style Selector="DatePicker /template/ TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TimePicker /template/ TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</Styles>
