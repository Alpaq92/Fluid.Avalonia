<!--
    ProgressCircle — a determinate radial progress indicator: a track ring with an accent fill arc that
    sweeps clockwise from 12 o'clock to show how far Value has progressed between Minimum and Maximum,
    with the percentage in the centre. Shares the RadialDial ring rendering with RadialSlider and the
    RadialTimePicker dial, but is non-interactive and filled with the app accent.
-->
<UserControl
    x:Class="Avalonia.Fluid.Demo.Controls.ProgressCircle"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="140" Height="140">
        <Canvas x:Name="Face" Width="140" Height="140" />
        <TextBlock x:Name="ValueText" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="22"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
    </Grid>
</UserControl>
