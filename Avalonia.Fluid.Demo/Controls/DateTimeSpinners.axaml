<!--
    DateTimeSpinners — the looping spinner-column date + time picker on its own (no field, no
    OK/Cancel): month / day / year · hour : minute · AM-PM as adjacent looping columns built on
    Avalonia's DateTimePickerPanel. It edits its TwoWay SelectedDateTime live as you scroll; hosts seed
    it on open and read it back on commit. ClockIdentifier chooses 12-hour (with AM/PM) or 24-hour.
    Used inline and hosted by DateTimePicker (its flyout) so the wheels are identical in both.
-->
<UserControl
    x:Class="Avalonia.Fluid.Demo.Controls.DateTimeSpinners"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prim="using:Avalonia.Controls.Primitives">

    <UserControl.Styles>
        <!-- Scroller columns: centred items, looping selector. -->
        <Style Selector="ScrollViewer.dtp-col > prim|DateTimePickerPanel">
            <Setter Property="TextElement.FontSize" Value="14" />
        </Style>
    </UserControl.Styles>

    <!-- Looping spinner columns. The columns sit directly adjacent (no separator column), so the
         selected (centered) item in each forms one continuous accent band with no gap. The date/time
         divider is a zero-width overlay split into two segments that stop short of the centre band. A
         faint band backs the whole row. -->
    <Grid x:Name="ScrollerContent" Height="266" ColumnDefinitions="124,62,78,62,62,Auto">
        <Border Grid.Column="0" Grid.ColumnSpan="6" Height="38" VerticalAlignment="Center"
                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                CornerRadius="4" />

        <ScrollViewer Grid.Column="0" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="MonthPanel" PanelType="Month" ItemFormat="MMMM" ItemHeight="38" ShouldLoop="True" />
        </ScrollViewer>
        <ScrollViewer Grid.Column="1" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="DayPanel" PanelType="Day" ItemFormat="%d" ItemHeight="38" ShouldLoop="True" />
        </ScrollViewer>
        <ScrollViewer Grid.Column="2" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="YearPanel" PanelType="Year" ItemFormat="yyyy" ItemHeight="38" ShouldLoop="False" />
        </ScrollViewer>
        <ScrollViewer Grid.Column="3" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="HourPanel" PanelType="Hour" ItemFormat="%h" ItemHeight="38" ShouldLoop="True" />
        </ScrollViewer>
        <ScrollViewer Grid.Column="4" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="MinutePanel" PanelType="Minute" ItemFormat="mm" ItemHeight="38" ShouldLoop="True" />
        </ScrollViewer>
        <ScrollViewer x:Name="PeriodHost" Grid.Column="5" Width="70" Classes="dtp-col" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <prim:DateTimePickerPanel x:Name="PeriodPanel" PanelType="TimePeriod" ItemHeight="38" ShouldLoop="False" />
        </ScrollViewer>

        <!-- date/time divider: split so it stops short of the centre selection band. -->
        <Grid Grid.Column="2" Width="1" HorizontalAlignment="Right" RowDefinitions="*,38,*">
            <Rectangle Grid.Row="0" Width="1" Margin="0,8,0,4" VerticalAlignment="Stretch"
                       Fill="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Rectangle Grid.Row="2" Width="1" Margin="0,4,0,8" VerticalAlignment="Stretch"
                       Fill="{DynamicResource ControlStrokeColorDefaultBrush}" />
        </Grid>
    </Grid>
</UserControl>
