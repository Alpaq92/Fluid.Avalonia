<UserControl
    x:Class="Avalonia.Fluid.Demo.Views.Pages.DialogsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Avalonia.Fluid.Demo.Controls">

    <StackPanel>

        <ctrls:ControlExample Header="A Flyout shows lightweight, dismissable content."
                              XamlSource="&lt;Button Content=&quot;Empty the recycle bin&quot;&gt;&lt;Button.Flyout&gt;&lt;Flyout&gt;...&lt;/Flyout&gt;&lt;/Button.Flyout&gt;&lt;/Button&gt;">
            <Button Content="Empty the recycle bin">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Width="240" Spacing="12">
                            <TextBlock Classes="Body" TextWrapping="Wrap"
                                       Text="All items will be permanently deleted." />
                            <Button Classes="accent" HorizontalAlignment="Right" Content="Empty" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A MenuFlyout presents a list of commands."
                              XamlSource="&lt;Button Content=&quot;Show menu&quot;&gt;&lt;Button.Flyout&gt;&lt;MenuFlyout&gt;&lt;MenuItem Header=&quot;Share&quot; /&gt;&lt;MenuItem Header=&quot;Copy&quot; /&gt;&lt;/MenuFlyout&gt;&lt;/Button.Flyout&gt;&lt;/Button&gt;">
            <Button Content="Show menu">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="Share" />
                        <MenuItem Header="Copy" />
                        <MenuItem Header="Rename" />
                        <Separator />
                        <MenuItem Header="Delete" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A faux ContentDialog surface (Smoke layer + 8px card)."
                              XamlSource="&lt;Border CornerRadius=&quot;{DynamicResource OverlayCornerRadius}&quot; BoxShadow=&quot;{DynamicResource DialogBoxShadow}&quot;&gt;...&lt;/Border&gt;">
            <Border
                Width="380"
                Padding="24"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="1"
                BoxShadow="{DynamicResource DialogBoxShadow}"
                CornerRadius="{DynamicResource OverlayCornerRadius}">
                <StackPanel Spacing="12">
                    <TextBlock Classes="Subtitle" Text="Delete file?" />
                    <TextBlock Classes="Body" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="This item will be permanently removed and can't be recovered." />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Classes="accent" Content="Delete" />
                        <Button Content="Cancel" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ctrls:ControlExample>

    </StackPanel>
</UserControl>
