<UserControl
    x:Class="Avalonia.Fluid.Demo.Views.Pages.MenusPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:Avalonia.Fluid.Demo.Controls">

    <StackPanel>

        <ctrls:ControlExample Header="A Menu bar with drop-down submenus."
                              XamlSource="&lt;Menu&gt;&lt;MenuItem Header=&quot;_File&quot;&gt;&lt;MenuItem Header=&quot;New&quot; /&gt;&lt;MenuItem Header=&quot;Exit&quot; /&gt;&lt;/MenuItem&gt;&lt;/Menu&gt;">
            <Menu Width="420" HorizontalAlignment="Left">
                <MenuItem Header="_File">
                    <MenuItem Header="New" />
                    <MenuItem Header="Open…" />
                    <Separator />
                    <MenuItem Header="Exit" />
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="Cut" />
                    <MenuItem Header="Copy" />
                    <MenuItem Header="Paste" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Zoom in" />
                    <MenuItem Header="Zoom out" />
                </MenuItem>
            </Menu>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A command bar of icon buttons."
                              XamlSource="&lt;StackPanel Orientation=&quot;Horizontal&quot;&gt;&lt;Button&gt;&lt;TextBlock Text=&quot;&amp;#xE70F;&quot; /&gt;&lt;/Button&gt;&lt;/StackPanel&gt;">
            <Border
                Padding="6"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource ControlCornerRadius}">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEA73;" />
                    </Button>
                    <Button Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEBCC;" />
                    </Button>
                    <Button Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEA81;" />
                    </Button>
                    <Button Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0">
                        <TextBlock FontFamily="{DynamicResource SymbolThemeFontFamily}" FontSize="16" Text="&#xEA7C;" />
                    </Button>
                </StackPanel>
            </Border>
        </ctrls:ControlExample>

        <ctrls:ControlExample Header="A ContextMenu (right-click the area below)."
                              XamlSource="&lt;Border&gt;&lt;Border.ContextMenu&gt;&lt;ContextMenu&gt;&lt;MenuItem Header=&quot;Cut&quot; /&gt;&lt;MenuItem Header=&quot;Copy&quot; /&gt;&lt;/ContextMenu&gt;&lt;/Border.ContextMenu&gt;&lt;/Border&gt;">
            <Border
                Width="280"
                Height="100"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource ControlCornerRadius}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           Classes="Body" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Right-click here" />
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Cut" />
                        <MenuItem Header="Copy" />
                        <MenuItem Header="Paste" />
                        <Separator />
                        <MenuItem Header="Select all" />
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
        </ctrls:ControlExample>

    </StackPanel>
</UserControl>
